{
  "name": "loopdeck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "loopdeck": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "pnpm run build:server && pnpm run build:web",
    "build:server": "tsc",
    "build:web": "node scripts/build-web.mjs",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "fastify": "^5.2.0",
    "get-port": "^7.1.0",
    "open": "^10.1.0",
    "p-limit": "^6.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
